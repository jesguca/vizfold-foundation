generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ModelBackend {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  label            String
  summary          String
  capabilitiesJson String
  runs             Run[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ExecutionTarget {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  label       String
  summary     String
  kind        String   // "local_mock", "local_runtime", "hpc", "gateway"
  status      String   // "available", "planned", "disabled"
  configJson  String?
  runs        Run[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Run {
  id                Int             @id @default(autoincrement())

  jobName           String
  inputText         String
  status            String
  outputJson        String?

  modelBackendId    Int
  modelBackend      ModelBackend    @relation(fields: [modelBackendId], references: [id])

  executionTargetId Int
  executionTarget   ExecutionTarget @relation(fields: [executionTargetId], references: [id])

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}
